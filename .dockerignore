**/__pycache__/
**/*.pyc
**/.venv/
**/venv/
**/models/*.joblib
**/*.pkl

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Docker
*.log
*.pid
*.seed

